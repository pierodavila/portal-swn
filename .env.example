# Copie para .env e ajuste para rodar local. NÃO comite o .env real.

# Chave de assinatura da sessão Flask. Gere uma forte em produção, ex.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave

# Banco. Deixe VAZIO/ausente para usar SQLite local (arquivo portal.db).
# Em produção o Render injeta a URL do Postgres automaticamente.
# DATABASE_URL=postgresql://usuario:senha@host:5432/portal_swn
DATABASE_URL=

# Admin inicial criado no primeiro boot se o banco estiver vazio.
ADMIN_EMAIL=admin@swn.local
ADMIN_PASSWORD=troque-imediatamente

# Debug local (deixa cookies sem 'Secure' p/ funcionar em http://localhost).
FLASK_DEBUG=1
